# ── Copy to .env and edit as needed ──
# Phase 0/1 work with all defaults; nothing here is strictly required.

ENVIRONMENT=development
DEBUG=true

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Reddit ──
# Reddit's public .json endpoint requires a descriptive User-Agent.
# Format: <platform>:<app id>:<version> (by /u/<username>)
REDDIT_USER_AGENT=web:slopgraph.hackathon:0.1.0 (by /u/slopgraph_scanner)

# When true, the Reddit adapter returns a bundled fixture instead of
# making a live network call. Useful when:
#   • You're demoing offline.
#   • Reddit is blocking your IP (datacenter ranges, some ISPs, CI).
# Set to "true" / "1" / "yes" to enable.
USE_DEMO_FIXTURE=false

# ── YouTube (Phase 6 — cross-platform) ──
# Get a free key from: Google Cloud Console → APIs & Services → Credentials
# Enable "YouTube Data API v3" first, then create an API Key.
# Without this key, YouTube URLs return a clear error message.
# Reddit and Amazon work without any API key.
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
